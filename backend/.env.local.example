LOCAL_MODE=true
NODE_ENV=production
PORT=3000

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=moneyflow
DATABASE_PASSWORD=change_this_local_database_password
DATABASE_NAME=moneyflow_local
TYPEORM_SYNCHRONIZE=false

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=REPLACE_WITH_GENERATED_LOCAL_JWT_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_GENERATED_LOCAL_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d
CSRF_SECRET=REPLACE_WITH_GENERATED_LOCAL_CSRF_SECRET

FRONTEND_URL=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

MAIL_PROVIDER=log
MAIL_FROM=Comptario Local <noreply@localhost.local>
MAIL_REPLY_TO=
EMAIL_VERIFICATION_REQUIRED=false

TURNSTILE_SECRET_KEY=
TURNSTILE_DEV_BYPASS=true
LOGIN_FAILED_CAPTCHA_THRESHOLD=5

STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

SECURITY_ENABLE_CSP_NONCE=false
PASSWORD_MIN_LENGTH=8
PASSWORD_MIN_SCORE=0
